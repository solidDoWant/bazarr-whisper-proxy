# Copy this file to .env and uncomment / edit values as needed.
# Defaults shown match the application defaults from SPEC §5.

# OpenArc backend
# OPENARC_BASE_URL=http://localhost:8000
# OPENARC_MODEL=qwen3-asr-0_6b-int8-asym
# OPENARC_READ_TIMEOUT=3000
# OPENARC_CONNECT_TIMEOUT=5

# Forced aligner
# ALIGNER_MODEL=mms-1b-all
# ALIGNER_BATCH_SIZE=16
# ALIGNER_WINDOW_SEC=30

# Language detection
# LANG_DETECT_HEAD_SEC=30

# SRT assembly
# CUE_MAX_CHARS=84
# CUE_MAX_SEC=6.0
# CUE_MIN_SEC=1.0
# CUE_SILENCE_MS=700

# Audio
# MAX_AUDIO_BYTES=200000000

# Logging
# LOG_LEVEL=INFO
# LOG_FORMAT=json
